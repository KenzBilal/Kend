{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "redirects": [
    { "source": "/", "destination": "https://t.me/Any_wherebot", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/send/(.*)", "destination": "/index.html" }
  ]
}
